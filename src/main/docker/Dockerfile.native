FROM registry.access.redhat.com/ubi8/ubi-minimal@sha256:7eedea3d199fd9b0e6a06cd1a22537c1b84fab65d6eec8a5049c12e68c57f692
WORKDIR /work/
COPY target/*-runner /work/application
RUN chmod 775 /work
USER 1001
EXPOSE 8080
ENV LISTEN_HOST=${LISTEN_HOST:-0.0.0.0}
CMD ["./application", "-Dquarkus.http.host=${LISTEN_HOST}"]
