FROM registry.access.redhat.com/ubi8/ubi-minimal@sha256:68707a76df71bf79b2355d93ae464a14183a23fcf02b2e26241eb4dcf71a11b3
WORKDIR /work/
COPY target/*-runner /work/application
RUN chmod 775 /work
USER 1001
EXPOSE 8080
ENV LISTEN_HOST=${LISTEN_HOST:-0.0.0.0}
CMD ["./application", "-Dquarkus.http.host=${LISTEN_HOST}"]
