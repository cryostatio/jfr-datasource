FROM registry.access.redhat.com/ubi8/ubi-minimal@sha256:61e4f7716c700562f8e8882913a99677748918aa5a534929990d02c1bae10ca4
WORKDIR /work/
COPY target/*-runner /work/application
RUN chmod 775 /work
USER 1001
EXPOSE 8080
ENV LISTEN_HOST=${LISTEN_HOST:-0.0.0.0}
CMD ["./application", "-Dquarkus.http.host=${LISTEN_HOST}"]
