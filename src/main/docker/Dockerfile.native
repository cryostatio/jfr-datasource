FROM registry.access.redhat.com/ubi8/ubi-minimal@sha256:578b238953144445a9b5bb2487eb1d95df4886f98d1f73c4a070b27535f51688
WORKDIR /work/
COPY target/*-runner /work/application
RUN chmod 775 /work
USER 1001
EXPOSE 8080
ENV LISTEN_HOST=${LISTEN_HOST:-0.0.0.0}
CMD ["./application", "-Dquarkus.http.host=${LISTEN_HOST}"]
